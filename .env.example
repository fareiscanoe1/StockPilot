# PostgreSQL (see docker-compose.yml for local defaults)
DATABASE_URL="postgresql://earnings:earnings@localhost:5432/earnings_pilot"

# Auth.js / NextAuth — use a long random string in production
AUTH_SECRET="change-me-in-production-min-32-chars-please"
NEXTAUTH_URL="http://localhost:3000"

# STRICT (required): real vendor data only. Missing keys disable features — no mock fallback.
DATA_PROVIDER="STRICT"

# Polygon — US stocks, aggregates, options (https://polygon.io)
POLYGON_API_KEY=""

# Finnhub — quotes if no Polygon, earnings calendar, market + company news (https://finnhub.io)
FINNHUB_API_KEY=""

# Tavily — web search context per ticker (https://tavily.com)
TAVILY_API_KEY=""

# OpenAI — structured trade reasoning only (normalized Polygon/Finnhub snapshot in → JSON out)
OPENAI_API_KEY=""
# Optional; default gpt-4o-mini
OPENAI_REASONING_MODEL=""

# Cron worker auth for POST /api/cron/scan
CRON_SECRET=""

# Alerts
TELEGRAM_BOT_TOKEN=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""
SMS_WEBHOOK_URL=""
